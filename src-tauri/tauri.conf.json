{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "ui",
  "version": "0.1.0",
  "identifier": "com.etheriutremake.awp",
  "build": {
    "frontendDist": "../src"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "ui",
        "width": 800,
        "height": 600,
        "decorations": false,
        "transparent": true,
        "shadow": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/icon.ico"
    ]
  }
  
}
